# Backend Environment Variables
# Copy this file to .env and fill in your actual values

# Port the backend server will run on
PORT=5000

# MongoDB connection string (get this from MongoDB Atlas or your local MongoDB)
# Format: mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
MONGO_URI=mongodb+srv://your_username:your_password@cluster0.example.mongodb.net/thecontrractum?retryWrites=true&w=majority
