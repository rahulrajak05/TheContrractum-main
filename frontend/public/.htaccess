<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Let /api/ requests pass through to the PHP proxy
  RewriteRule ^api(/|$) - [L]

  RewriteRule ^index\.html$ - [L]
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteCond %{REQUEST_FILENAME} !-l
  RewriteRule . /index.html [L]
</IfModule>
